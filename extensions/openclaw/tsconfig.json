{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "openclaw.plugin.json"]
}
